# ============================================
# متغيرات البيئة - Railway MySQL
# Environment Variables for Railway MySQL
# ============================================

# يتم توفير هذه المتغيرات تلقائياً من Railway عند ربط خدمة MySQL
# These are auto-provided by Railway when you attach a MySQL plugin

# --- Railway MySQL Variables (auto-injected by Railway) ---
MYSQL_DATABASE=railway
MYSQLHOST=                     # auto: ${{RAILWAY_PRIVATE_DOMAIN}}
MYSQLPORT=3306
MYSQLUSER=root
MYSQLPASSWORD=                 # auto: ${{MYSQL_ROOT_PASSWORD}}

# Railway also provides ready-to-use connection strings:
# MYSQL_URL=mysql://root:<password>@<private-domain>:3306/railway        (internal)
# MYSQL_PUBLIC_URL=mysql://root:<password>@<tcp-proxy>:<port>/railway    (external)

# --- App Settings ---
SESSION_SECRET=change_this_to_a_long_random_secret_in_production
PORT=3000
NODE_ENV=production
