# ──────────────────────────────────────────────────────────
# Variables d'environnement — Centre de Soutien Scolaire
# Copiez ce fichier en ".env" pour le développement local.
# Sur Railway, ajoutez ces variables dans l'onglet "Variables".
# ──────────────────────────────────────────────────────────

# Construit automatiquement depuis les variables MySQL Railway :
# Dans Railway → Variables de votre service Node.js, ajoutez :
# DATABASE_URL = ${{MySQL.MYSQL_URL}}
DATABASE_URL="mysql://USER:PASSWORD@HOST:PORT/DATABASE"

# Variables MySQL Railway (injectées automatiquement par Railway)
MYSQLUSER=root
MYSQLPASSWORD=your_password
MYSQLHOST=containers-us-west-xxx.railway.app
MYSQLPORT=6543
MYSQLDATABASE=railway
MYSQL_URL=mysql://root:your_password@containers-us-west-xxx.railway.app:6543/railway

# App
NODE_ENV=production
PORT=3000

# Sécurité session (changez cette valeur !)
SESSION_SECRET=changez-ce-secret-maintenant-2024

# Initialisation admin (pour la route /init-admin?secret=XXX)
INIT_SECRET=votre-secret-init-unique
ADMIN_PASSWORD=Admin@2024!
