<%
  const title = 'Gestion Finance';
  const activeMenu = 'finance';
  const ALL_NIVEAUX = ['AC1','AC2','AC3','TC','BAC1','BAC2'];
  const ALL_MATIERES = Object.keys(MATIERES_LABELS);
%>
<%- include('partials/header', { extraCss: '' }) %>

<div class="page-header d-flex justify-content-between align-items-center flex-wrap gap-2">
  <div>
    <h4><i class="bi bi-cash-coin me-2 text-warning"></i>Gestion des Paiements</h4>
    <small class="text-muted">Saisie manuelle des recettes mensuelles</small>
  </div>
</div>

<!-- Filtres -->
<div class="card mb-3 p-3">
  <form method="GET" class="row g-2 align-items-end">
    <div class="col-auto">
      <label class="form-label small fw-semibold mb-1">Mois</label>
      <select name="mois" class="form-select form-select-sm" style="width:auto">
        <% for (let m = 1; m <= 12; m++) { %>
        <option value="<%= m %>" <%= m === mois ? 'selected' : '' %>><%= MOIS_LABELS[m] %></option>
        <% } %>
      </select>
    </div>
    <div class="col-auto">
      <label class="form-label small fw-semibold mb-1">Année</label>
      <input type="number" name="annee" class="form-control form-control-sm" value="<%= annee %>" style="width:90px" min="2020" max="2099">
    </div>
    <div class="col-auto">
      <label class="form-label small fw-semibold mb-1">Matière</label>
      <select name="matiere" class="form-select form-select-sm" style="width:auto">
        <option value="">Toutes les matières</option>
        <% ALL_MATIERES.forEach(m => { %>
        <option value="<%= m %>" <%= matiere === m ? 'selected' : '' %>><%= MATIERES_LABELS[m] %></option>
        <% }) %>
      </select>
    </div>
    <div class="col-auto">
      <label class="form-label small fw-semibold mb-1">Niveau</label>
      <select name="niveau" class="form-select form-select-sm" style="width:auto">
        <option value="">Tous les niveaux</option>
        <% ALL_NIVEAUX.forEach(n => { %>
        <option value="<%= n %>" <%= niveau === n ? 'selected' : '' %>><%= NIVEAUX_LABELS[n] %></option>
        <% }) %>
      </select>
    </div>
    <div class="col-auto">
      <button type="submit" class="btn btn-sm btn-primary">Afficher</button>
    </div>
  </form>
</div>

<div class="card">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead>
          <tr>
            <th>Élève</th>
            <th>Niveau</th>
            <th>Matière(s)</th>
            <th>Montant (MAD)</th>
            <th>Date de paiement</th>
            <th>Statut</th>
            <th style="width:100px">Action</th>
          </tr>
        </thead>
        <tbody>
          <% if (students.length === 0) { %>
          <tr><td colspan="7" class="text-center text-muted py-4">Aucun élève trouvé pour ce filtre.</td></tr>
          <% } %>
          <% students.forEach(s => { %>
          <% const p = s.paiements[0] || null; %>
          <%
            const minDate = annee + '-' + String(mois).padStart(2,'0') + '-01';
            const lastDay = new Date(annee, mois, 0).getDate();
            const maxDate = annee + '-' + String(mois).padStart(2,'0') + '-' + String(lastDay).padStart(2,'0');
            let dateVal = '';
            if (p && p.datePaiement) {
              const d = new Date(p.datePaiement);
              if ((d.getMonth() + 1) === mois && d.getFullYear() === annee) {
                dateVal = d.toISOString().split('T')[0];
              }
            }
          %>
          <tr id="row-<%= s.id %>">
            <td class="fw-medium"><%= s.prenom %> <%= s.nom %></td>
            <td><span class="badge badge-niveau"><%= NIVEAUX_LABELS[s.niveau] %></span></td>
            <td>
              <% s.inscriptions.forEach(ins => { %>
                <span class="badge bg-secondary me-1" style="font-size:.72rem"><%= MATIERES_LABELS[ins.matiere] %></span>
              <% }) %>
              <% if (s.inscriptions.length === 0) { %>
                <span class="text-muted small">—</span>
              <% } %>
            </td>
            <td>
              <input type="number" class="form-control form-control-sm montant-input" step="0.01" min="0"
                value="<%= p ? Number(p.montant).toFixed(2) : '0.00' %>"
                data-id="<%= s.id %>" style="width: 110px">
            </td>
            <td>
              <input type="date"
                class="form-control form-control-sm date-input"
                data-id="<%= s.id %>"
                value="<%= dateVal %>"
                min="<%= minDate %>"
                max="<%= maxDate %>"
                style="width: 150px">
            </td>
            <td>
              <% if (p && p.paye) { %>
                <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Payé</span>
                <% if (p.datePaiement) { %>
                  <small class="text-muted ms-1"><%= new Date(p.datePaiement).toLocaleDateString('fr-MA') %></small>
                <% } %>
              <% } else { %>
                <span class="badge bg-danger"><i class="bi bi-x-circle me-1"></i>Non payé</span>
              <% } %>
            </td>
            <td class="d-flex gap-1">
              <button class="btn btn-sm btn-success btn-payer" data-id="<%= s.id %>" title="Marquer payé">
                <i class="bi bi-check-lg"></i>
              </button>
              <button class="btn btn-sm btn-outline-secondary btn-imapye" data-id="<%= s.id %>" title="Marquer impayé">
                <i class="bi bi-x-lg"></i>
              </button>
            </td>
          </tr>
          <% }) %>
        </tbody>
        <%
          const totalPayes   = students.reduce((sum, s) => sum + (s.paiements[0] && s.paiements[0].paye   ? Number(s.paiements[0].montant) : 0), 0);
          const totalImpayes = students.reduce((sum, s) => sum + (s.paiements[0] && !s.paiements[0].paye  ? Number(s.paiements[0].montant) : 0), 0);
          const totalGlobal  = students.reduce((sum, s) => sum + (s.paiements[0] ? Number(s.paiements[0].montant) : 0), 0);
        %>
        <tfoot class="table-light border-top border-2">
          <tr>
            <td colspan="3" class="text-end fw-bold">Total</td>
            <td>
              <div class="fw-bold fs-6"><%= totalGlobal.toFixed(2) %> <span class="text-muted small">MAD</span></div>
              <div class="small text-success"><i class="bi bi-check-circle me-1"></i><%= totalPayes.toFixed(2) %> payé</div>
              <div class="small text-danger"><i class="bi bi-x-circle me-1"></i><%= totalImpayes.toFixed(2) %> impayé</div>
            </td>
            <td colspan="3"></td>
          </tr>
        </tfoot>
      </table>
    </div>
  </div>
</div>

<%- include('partials/footer', { extraJs: `
<script>
const mois = ${mois}, annee = ${annee};

function validateDate(dateStr) {
  if (!dateStr) return true;
  const d = new Date(dateStr + 'T00:00:00');
  return (d.getMonth() + 1) === mois && d.getFullYear() === annee;
}

async function savePaiement(studentId, paye) {
  const montantEl = document.querySelector('.montant-input[data-id="' + studentId + '"]');
  const dateEl    = document.querySelector('.date-input[data-id="' + studentId + '"]');
  const montant   = parseFloat(montantEl.value) || 0;
  const dateValue = dateEl ? dateEl.value : '';

  if (paye && dateValue && !validateDate(dateValue)) {
    alert('La date doit être dans le mois sélectionné (' + String(mois).padStart(2,'0') + '/' + annee + ').');
    dateEl.focus();
    return;
  }

  const res = await fetch('/admin/finance/paiement', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      studentId,
      mois,
      annee,
      montant,
      paye: paye ? '1' : '0',
      datePaiement: paye ? (dateValue || null) : null
    })
  });
  if (res.ok) location.reload();
  else alert('Erreur lors de la sauvegarde.');
}

document.querySelectorAll('.btn-payer').forEach(btn => {
  btn.addEventListener('click', () => savePaiement(btn.dataset.id, true));
});
document.querySelectorAll('.btn-imapye').forEach(btn => {
  btn.addEventListener('click', () => savePaiement(btn.dataset.id, false));
});
</script>
` }) %>
