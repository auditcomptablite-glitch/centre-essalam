<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= typeof title !== 'undefined' ? title : 'Centre de Soutien' %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <style>
    :root {
      --primary: #1a3a5c;
      --accent: #e8a020;
      --sidebar-w: 240px;
    }
    body { font-family: 'Segoe UI', system-ui, sans-serif; background: #f0f4f8; }
    .sidebar {
      width: var(--sidebar-w); min-height: 100vh; background: var(--primary);
      position: fixed; top: 0; left: 0; z-index: 100; display: flex; flex-direction: column;
    }
    .sidebar-brand {
      padding: 1.25rem 1rem; background: rgba(0,0,0,.2);
      color: var(--accent); font-weight: 700; font-size: 1rem; text-decoration: none;
      display: flex; align-items: center; gap: .5rem;
    }
    .sidebar-brand small { color: rgba(255,255,255,.6); font-size: .7rem; font-weight: 400; display: block; }
    .sidebar .nav-link {
      color: rgba(255,255,255,.75); padding: .65rem 1rem; border-radius: .375rem;
      margin: .1rem .5rem; display: flex; align-items: center; gap: .6rem;
      transition: background .15s, color .15s;
    }
    .sidebar .nav-link:hover, .sidebar .nav-link.active {
      background: rgba(255,255,255,.12); color: #fff;
    }
    .sidebar .nav-link i { font-size: 1.1rem; width: 1.3rem; text-align: center; }
    .main-content { margin-left: var(--sidebar-w); padding: 1.5rem; min-height: 100vh; }
    .page-header { background: #fff; border-radius: .5rem; padding: 1rem 1.25rem; margin-bottom: 1.25rem; border-left: 4px solid var(--accent); }
    .page-header h4 { margin: 0; font-weight: 600; color: var(--primary); }
    .card { border: none; border-radius: .5rem; box-shadow: 0 1px 4px rgba(0,0,0,.08); }
    .stat-card { border-left: 4px solid var(--accent); }
    .stat-card .stat-num { font-size: 2rem; font-weight: 700; color: var(--primary); line-height: 1; }
    .badge-niveau { background: #e3edf7; color: var(--primary); font-weight: 600; }
    .table th { background: #f8fafc; font-size: .82rem; text-transform: uppercase; letter-spacing: .04em; color: #64748b; }
    .btn-primary { background: var(--primary); border-color: var(--primary); }
    .btn-primary:hover { background: #14304e; border-color: #14304e; }
    .btn-warning { background: var(--accent); border-color: var(--accent); color: #fff; }
    @media (max-width: 768px) {
      .sidebar { transform: translateX(-100%); transition: transform .25s ease; }
      .sidebar.open { transform: translateX(0); }
      .sidebar-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,.4); z-index: 99; }
      .sidebar-overlay.open { display: block; }
      .main-content { margin-left: 0; padding: 1rem; }
      .mobile-nav { display: flex !important; }
      .w-md-auto { width: auto !important; }
    }
    @media (min-width: 769px) {
      .mobile-nav { display: none !important; }
      .sidebar { transform: none !important; }
    }
  </style>
  <%- typeof extraCss !== 'undefined' ? extraCss : '' %>
</head>
<body>

<!-- Overlay mobile -->
<div class="sidebar-overlay" id="sidebarOverlay"></div>

<!-- Navbar mobile -->
<nav class="mobile-nav align-items-center justify-content-between px-3 py-2 bg-white shadow-sm"
  style="position:sticky;top:0;z-index:98;border-bottom:1px solid #e2e8f0">
  <button class="btn btn-sm btn-outline-secondary" id="menuToggle">
    <i class="bi bi-list fs-5"></i>
  </button>
  <span class="fw-bold" style="color:var(--primary);font-size:.95rem">
    <i class="bi bi-mortarboard-fill me-1" style="color:var(--accent)"></i>Centre de Soutien
  </span>
  <a href="/logout" class="btn btn-sm btn-outline-danger">
    <i class="bi bi-box-arrow-right"></i>
  </a>
</nav>

<div class="sidebar" id="sidebar">
  <a href="#" class="sidebar-brand">
    <i class="bi bi-mortarboard-fill fs-4"></i>
    <div>Centre de Soutien<small>Tableau de bord</small></div>
  </a>
  <nav class="flex-grow-1 py-2">
    <% if (user && user.role === 'ADMIN') { %>
    <a href="/admin" class="nav-link <%= typeof activeMenu !== 'undefined' && activeMenu === 'dashboard' ? 'active' : '' %>">
      <i class="bi bi-speedometer2"></i> Dashboard
    </a>
    <a href="/admin/etudiants" class="nav-link <%= typeof activeMenu !== 'undefined' && activeMenu === 'etudiants' ? 'active' : '' %>">
      <i class="bi bi-people"></i> Élèves
    </a>
    <a href="/admin/finance" class="nav-link <%= typeof activeMenu !== 'undefined' && activeMenu === 'finance' ? 'active' : '' %>">
      <i class="bi bi-cash-coin"></i> Finance
    </a>
    <a href="/admin/profs" class="nav-link <%= typeof activeMenu !== 'undefined' && activeMenu === 'profs' ? 'active' : '' %>">
      <i class="bi bi-person-badge"></i> Professeurs
    </a>
    <a href="/admin/seances" class="nav-link <%= typeof activeMenu !== 'undefined' && activeMenu === 'seances' ? 'active' : '' %>">
      <i class="bi bi-calendar2-check"></i> Séances
    </a>
    <% } else if (user && user.role === 'PROFESSOR') { %>
    <a href="/prof" class="nav-link <%= typeof activeMenu !== 'undefined' && activeMenu === 'appel' ? 'active' : '' %>">
      <i class="bi bi-clipboard-check"></i> Feuille d'appel
    </a>
    <a href="/prof/seances" class="nav-link <%= typeof activeMenu !== 'undefined' && activeMenu === 'seances' ? 'active' : '' %>">
      <i class="bi bi-calendar2-check"></i> Mes séances
    </a>
    <% } %>
  </nav>
  <div class="p-3" style="border-top: 1px solid rgba(255,255,255,.1)">
    <div class="text-white-50 small mb-2">
      <i class="bi bi-person-circle me-1"></i><strong class="text-white"><%= user ? user.username : '' %></strong>
      <span class="ms-1 badge bg-warning text-dark" style="font-size:.65rem"><%= user ? user.role : '' %></span>
    </div>
    <a href="/change-password" class="btn btn-sm btn-outline-warning w-100 mb-2">
      <i class="bi bi-key me-1"></i>Changer mot de passe
    </a>
    <a href="/logout" class="btn btn-sm btn-outline-light w-100"><i class="bi bi-box-arrow-right me-1"></i>Déconnexion</a>
  </div>
</div>

<div class="main-content">
<script>
  const menuToggle   = document.getElementById('menuToggle');
  const sidebar      = document.getElementById('sidebar');
  const overlay      = document.getElementById('sidebarOverlay');
  function openSidebar()  { sidebar.classList.add('open'); overlay.classList.add('open'); }
  function closeSidebar() { sidebar.classList.remove('open'); overlay.classList.remove('open'); }
  menuToggle?.addEventListener('click', openSidebar);
  overlay?.addEventListener('click', closeSidebar);
</script>
<% if (typeof flash !== 'undefined' && flash) { %>
<div class="alert alert-<%= flash.type %> alert-dismissible fade show mx-0 mb-3 d-flex align-items-center gap-2"
  role="alert" id="flashMsg" style="border-radius:.5rem">
  <% if (flash.type === 'success') { %>
    <i class="bi bi-check-circle-fill fs-5"></i>
  <% } else { %>
    <i class="bi bi-exclamation-triangle-fill fs-5"></i>
  <% } %>
  <span><%= flash.message %></span>
  <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
</div>
<script>setTimeout(() => { const el = document.getElementById('flashMsg'); if(el) el.classList.remove('show'); }, 4000);</script>
<% } %>
