<%
  const title = 'Changer le mot de passe';
  const activeMenu = '';
%>
<%- include('partials/header') %>

<div class="page-header">
  <h4><i class="bi bi-key me-2 text-warning"></i>Changer le mot de passe</h4>
  <small class="text-muted">Valable pour votre compte : <strong><%= user.username %></strong></small>
</div>

<div class="row justify-content-center">
  <div class="col-md-5">
    <div class="card">
      <div class="card-body p-4">

        <% if (error) { %>
        <div class="alert alert-danger d-flex align-items-center gap-2 py-2">
          <i class="bi bi-exclamation-triangle-fill"></i>
          <span><%= error %></span>
        </div>
        <% } %>

        <% if (success) { %>
        <div class="alert alert-success d-flex align-items-center gap-2 py-2">
          <i class="bi bi-check-circle-fill"></i>
          <span><%= success %></span>
        </div>
        <% } %>

        <form method="POST" action="/change-password">
          <div class="mb-3">
            <label class="form-label small fw-semibold" for="oldPassword">
              <i class="bi bi-lock me-1"></i>Ancien mot de passe
            </label>
            <input type="password" class="form-control" id="oldPassword" name="oldPassword"
              placeholder="••••••••" required autocomplete="current-password">
          </div>

          <div class="mb-3">
            <label class="form-label small fw-semibold" for="newPassword">
              <i class="bi bi-lock-fill me-1"></i>Nouveau mot de passe
            </label>
            <input type="password" class="form-control" id="newPassword" name="newPassword"
              placeholder="••••••••" required minlength="6" autocomplete="new-password">
            <div class="form-text">Minimum 6 caractères.</div>
          </div>

          <div class="mb-4">
            <label class="form-label small fw-semibold" for="confirmPassword">
              <i class="bi bi-shield-check me-1"></i>Confirmer le nouveau mot de passe
            </label>
            <input type="password" class="form-control" id="confirmPassword" name="confirmPassword"
              placeholder="••••••••" required autocomplete="new-password">
          </div>

          <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary flex-grow-1">
              <i class="bi bi-save me-1"></i>Enregistrer
            </button>
            <a href="<%= user.role === 'ADMIN' ? '/admin' : '/prof' %>" class="btn btn-outline-secondary">
              Annuler
            </a>
          </div>
        </form>

      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
