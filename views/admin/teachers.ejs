<%- include('../layout', { body: `
<div class="page-header">
  <div>
    <div class="page-title"><i class="fas fa-chalkboard-teacher" style="color: var(--primary-light)"></i> إدارة الأساتذة</div>
    <div class="page-subtitle">${teachers.length} أستاذ مسجل</div>
  </div>
  <button class="btn btn-primary" onclick="openModal('addTeacherModal')">
    <i class="fas fa-user-plus"></i> إضافة أستاذ جديد
  </button>
</div>

<div class="card">
  ${teachers.length === 0 ? `
    <div class="empty-state">
      <div class="empty-icon">👩‍🏫</div>
      <div class="empty-title">لا يوجد أساتذة مسجلون</div>
      <p>أضف أول أستاذ للبدء</p>
    </div>` : `
  <div class="table-wrapper">
    <table>
      <thead>
        <tr><th>#</th><th>الاسم</th><th>اسم المستخدم</th><th>عدد الحصص</th><th>تاريخ الإضافة</th><th>إجراءات</th></tr>
      </thead>
      <tbody>
        ${teachers.map((t, i) => `
          <tr>
            <td class="text-muted">${i + 1}</td>
            <td><strong><i class="fas fa-user-tie"></i> ${t.name}</strong></td>
            <td><code style="background: var(--surface2); padding: 2px 8px; border-radius: 4px; font-size: 13px;">${t.username}</code></td>
            <td><span class="badge badge-info">${t.session_count} حصة</span></td>
            <td class="text-muted">${new Date(t.created_at).toLocaleDateString('ar-MA')}</td>
            <td>
              <form id="deleteTeacher${t.id}" action="/admin/teachers/${t.id}/delete" method="POST" style="display:inline;">
                <button type="button" class="btn btn-sm btn-danger" onclick="confirmDelete('deleteTeacher${t.id}', '${t.name}')">
                  <i class="fas fa-trash"></i>
                </button>
              </form>
            </td>
          </tr>`).join('')}
      </tbody>
    </table>
  </div>`}
</div>

<!-- Add Teacher Modal -->
<div id="addTeacherModal" class="modal-overlay">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title"><i class="fas fa-user-plus"></i> إضافة أستاذ جديد</div>
      <button class="modal-close" onclick="closeModal('addTeacherModal')">✕</button>
    </div>
    <form action="/admin/teachers" method="POST">
      <div class="form-group">
        <label class="form-label">الاسم الكامل <span class="required">*</span></label>
        <input type="text" name="name" class="form-control" placeholder="مثال: محمد الأمين" required>
      </div>
      <div class="form-group">
        <label class="form-label">اسم المستخدم <span class="required">*</span></label>
        <input type="text" name="username" class="form-control" placeholder="مثال: prof_amine" required>
      </div>
      <div class="form-group">
        <label class="form-label">كلمة المرور <span class="required">*</span></label>
        <input type="password" name="password" class="form-control" placeholder="كلمة مرور قوية" required minlength="6">
      </div>
      <div style="display: flex; gap: 10px; justify-content: flex-end; margin-top: 8px;">
        <button type="button" class="btn btn-outline" onclick="closeModal('addTeacherModal')">إلغاء</button>
        <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> إضافة</button>
      </div>
    </form>
  </div>
</div>
` }) %>
