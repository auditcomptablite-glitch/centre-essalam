<%- include('../layout', { body: `
<div class="page-header">
  <div>
    <div class="page-title"><i class="fas fa-users" style="color: var(--primary-light)"></i> إدارة التلاميذ</div>
    <div class="page-subtitle">${students.length} تلميذ مسجل</div>
  </div>
  <button onclick="document.getElementById('addStudentModal').style.display='flex'" class="btn btn-primary">
    <i class="fas fa-user-plus"></i> إضافة تلميذ
  </button>
</div>

<!-- Modal إضافة تلميذ -->
<div id="addStudentModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:9999;align-items:center;justify-content:center;padding:16px;">
  <div style="background:#fff;border-radius:16px;width:100%;max-width:600px;max-height:90vh;overflow-y:auto;box-shadow:0 20px 60px rgba(0,0,0,0.3);">
    <div style="padding:20px 24px;border-bottom:1px solid #f0f4f8;display:flex;align-items:center;justify-content:space-between;">
      <div style="font-size:17px;font-weight:700;color:#0e1b2a;"><i class="fas fa-user-plus" style="color:#0d7377;margin-left:8px;"></i> إضافة تلميذ جديد</div>
      <button onclick="document.getElementById('addStudentModal').style.display='none'" style="background:none;border:none;font-size:20px;cursor:pointer;color:#6b8299;">×</button>
    </div>
    <form action="/admin/students" method="POST" style="padding:24px;">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px;">
        <div style="grid-column:1/-1;">
          <label class="form-label">الاسم الكامل <span style="color:red">*</span></label>
          <input type="text" name="full_name" class="form-control" placeholder="أدخل الاسم الكامل" required>
        </div>
        <div>
          <label class="form-label">المستوى الدراسي <span style="color:red">*</span></label>
          <select name="level_id" class="form-control" required>
            <option value="">-- اختر المستوى --</option>
            ${levels.map(l => `<option value="${l.id}">${l.name}</option>`).join('')}
          </select>
        </div>
        <div>
          <label class="form-label">هاتف التلميذ</label>
          <input type="text" name="phone" class="form-control" placeholder="0600000000">
        </div>
        <div>
          <label class="form-label">هاتف ولي الأمر</label>
          <input type="text" name="parent_phone" class="form-control" placeholder="0600000000">
        </div>
        <div>
          <label class="form-label">الحالة المالية</label>
          <select name="financial_status" class="form-control">
            <option value="غير مدفوع">غير مدفوع</option>
            <option value="مدفوع جزئياً">مدفوع جزئياً</option>
            <option value="مدفوع">مدفوع</option>
          </select>
        </div>
        <div>
          <label class="form-label">المبلغ المدفوع (درهم)</label>
          <input type="number" name="amount_paid" class="form-control" value="0" min="0" step="0.01">
        </div>
        <div style="grid-column:1/-1;">
          <label class="form-label">المواد الدراسية <span style="font-size:12px;color:#6b8299;">(اختر مادة أو أكثر)</span></label>
          <div style="display:flex;flex-wrap:wrap;gap:10px;margin-top:6px;">
            ${subjects.map(s => `
              <label style="display:flex;align-items:center;gap:6px;background:#f4f7f9;padding:7px 12px;border-radius:8px;cursor:pointer;border:2px solid transparent;transition:all 0.15s;"
                     onmouseover="this.style.borderColor='#0d7377'" onmouseout="this.style.borderColor='transparent'">
                <input type="checkbox" name="subjects" value="${s.id}" style="width:15px;height:15px;accent-color:#0d7377;">
                <span style="font-size:13px;font-weight:500;">${s.name}</span>
              </label>`).join('')}
          </div>
        </div>
        <div style="grid-column:1/-1;">
          <label class="form-label">ملاحظات</label>
          <textarea name="notes" class="form-control" rows="2" placeholder="ملاحظات اختيارية..."></textarea>
        </div>
      </div>
      <div style="display:flex;gap:12px;justify-content:flex-end;border-top:1px solid #f0f4f8;padding-top:16px;">
        <button type="button" onclick="document.getElementById('addStudentModal').style.display='none'" class="btn btn-outline">إلغاء</button>
        <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> حفظ التلميذ</button>
      </div>
    </form>
  </div>
</div>

<!-- Filters -->
<div class="filters-bar">
  <form action="/admin/students" method="GET" style="display: flex; flex-wrap: wrap; gap: 16px; align-items: flex-end; width: 100%;">
    <div class="form-group" style="min-width: 150px; flex: 1;">
      <label class="form-label">المستوى</label>
      <select name="level_id" class="form-control">
        <option value="">كل المستويات</option>
        ${levels.map(l => `<option value="${l.id}" ${filters.level_id == l.id ? 'selected' : ''}>${l.name}</option>`).join('')}
      </select>
    </div>
    <div class="form-group" style="min-width: 150px; flex: 1;">
      <label class="form-label">المادة</label>
      <select name="subject_id" class="form-control">
        <option value="">كل المواد</option>
        ${subjects.map(s => `<option value="${s.id}" ${filters.subject_id == s.id ? 'selected' : ''}>${s.name}</option>`).join('')}
      </select>
    </div>
    <div class="form-group" style="min-width: 160px; flex: 1;">
      <label class="form-label">الحالة المالية</label>
      <select name="financial_status" class="form-control">
        <option value="">الكل</option>
        <option value="مدفوع" ${filters.financial_status === 'مدفوع' ? 'selected' : ''}>مدفوع</option>
        <option value="غير مدفوع" ${filters.financial_status === 'غير مدفوع' ? 'selected' : ''}>غير مدفوع</option>
        <option value="مدفوع جزئياً" ${filters.financial_status === 'مدفوع جزئياً' ? 'selected' : ''}>مدفوع جزئياً</option>
      </select>
    </div>
    <div class="form-group" style="min-width: 200px; flex: 2;">
      <label class="form-label">بحث بالاسم</label>
      <input type="text" name="search" class="form-control" placeholder="اسم التلميذ..." value="${filters.search || ''}">
    </div>
    <div style="display: flex; gap: 8px; padding-bottom: 0;">
      <button type="submit" class="btn btn-primary"><i class="fas fa-search"></i> بحث</button>
      <a href="/admin/students" class="btn btn-outline"><i class="fas fa-times"></i> مسح</a>
    </div>
  </form>
</div>

<div class="card">
  ${students.length === 0 ? `
    <div class="empty-state">
      <div class="empty-icon">👤</div>
      <div class="empty-title">لا يوجد تلاميذ</div>
      <p>لم يتم تسجيل أي تلميذ بعد أو لا توجد نتائج تطابق بحثك</p>
    </div>` : `
  <div class="table-wrapper">
    <table>
      <thead>
        <tr>
          <th>#</th><th>الاسم</th><th>المستوى</th><th>المواد</th>
          <th>الهاتف</th><th>الحالة المالية</th><th>المدفوع</th><th>إجراءات</th>
        </tr>
      </thead>
      <tbody>
        ${students.map((s, i) => `
          <tr>
            <td class="text-muted">${i + 1}</td>
            <td><strong>${s.full_name}</strong></td>
            <td><span class="badge badge-info">${s.level_name}</span></td>
            <td style="max-width: 180px; font-size: 13px;">${s.subjects || '-'}</td>
            <td class="text-muted" style="direction: ltr;">${s.phone || '-'}</td>
            <td>
              <span class="badge ${s.financial_status === 'مدفوع' ? 'badge-paid' : s.financial_status === 'مدفوع جزئياً' ? 'badge-partial' : 'badge-unpaid'}">
                ${s.financial_status}
              </span>
            </td>
            <td>${Number(s.amount_paid || 0).toLocaleString()} درهم</td>
            <td>
              <div class="d-flex gap-2">
                <a href="/admin/students/${s.id}" class="btn btn-sm btn-outline">
                  <i class="fas fa-edit"></i> تفاصيل
                </a>
              </div>
            </td>
          </tr>`).join('')}
      </tbody>
    </table>
  </div>`}
</div>
` }) %>
