<%- include('../layout', { body: `
<div class="page-header">
  <div>
    <div class="page-title"><i class="fas fa-chalkboard-teacher" style="color: var(--primary-light)"></i> لوحة الأستاذ</div>
    <div class="page-subtitle">مرحباً، ${user.name}</div>
  </div>
  <a href="/teacher/attendance-history" class="btn btn-outline">
    <i class="fas fa-history"></i> سجل الحصص السابقة
  </a>
</div>

<div class="card">
  <div class="card-header">
    <div class="card-title"><i class="fas fa-plus-circle"></i> تسجيل حصة جديدة</div>
  </div>

  <form action="/teacher/session" method="POST" id="sessionForm">
    <div class="form-grid">
      <div class="form-group">
        <label class="form-label">المادة الدراسية <span class="required">*</span></label>
        <select name="subject_id" id="subject_id" class="form-control" required onchange="onFilterChange()">
          <option value="">-- اختر المادة --</option>
          ${subjects.map(s => \`<option value="\${s.id}">\${s.name}</option>\`).join('')}
        </select>
      </div>

      <div class="form-group">
        <label class="form-label">المستوى الدراسي <span class="required">*</span></label>
        <select name="level_id" id="level_id" class="form-control" required onchange="onFilterChange()">
          <option value="">-- اختر المستوى --</option>
          ${levels.map(l => \`<option value="\${l.id}">\${l.name}</option>\`).join('')}
        </select>
      </div>

      <div class="form-group">
        <label class="form-label">تاريخ الحصة <span class="required">*</span></label>
        <input type="date" name="session_date" id="session_date" class="form-control" required value="${new Date().toISOString().split('T')[0]}">
      </div>

      <div class="form-group">
        <label class="form-label">وقت الحصة</label>
        <input type="time" name="session_time" class="form-control">
      </div>

      <div class="form-group form-full">
        <label class="form-label">ملاحظات الحصة</label>
        <input type="text" name="notes" class="form-control" placeholder="ملاحظات اختيارية...">
      </div>
    </div>

    <!-- قائمة التلاميذ والحضور -->
    <div class="form-group">
      <label class="form-label"><i class="fas fa-users"></i> قائمة التلاميذ وتسجيل الحضور</label>
      <div id="studentsContainer" style="min-height: 80px; background: var(--surface2); border-radius: var(--radius); padding: 16px; border: 2px dashed var(--border);">
        <p class="text-muted text-center" style="padding: 20px 0;">
          <i class="fas fa-arrow-up"></i> اختر المادة والمستوى أولاً لعرض قائمة التلاميذ
        </p>
      </div>
    </div>

    <div style="display: flex; gap: 12px; justify-content: flex-end; margin-top: 8px;">
      <button type="button" class="btn btn-outline" onclick="document.getElementById('sessionForm').reset(); document.getElementById('studentsContainer').innerHTML = '<p class=\\'text-muted text-center\\' style=\\'padding: 20px 0;\\'><i class=\\'fas fa-arrow-up\\'></i> اختر المادة والمستوى أولاً</p>';">
        <i class="fas fa-redo"></i> إعادة تعيين
      </button>
      <button type="submit" class="btn btn-primary">
        <i class="fas fa-save"></i> حفظ الحصة وتسجيل الحضور
      </button>
    </div>
  </form>
</div>

${recentSessions.length > 0 ? `
<div class="card" style="margin-top: 24px;">
  <div class="card-header">
    <div class="card-title"><i class="fas fa-clock"></i> آخر الحصص</div>
    <a href="/teacher/attendance-history" class="btn btn-sm btn-outline">عرض الكل</a>
  </div>
  <div class="table-wrapper">
    <table>
      <thead>
        <tr>
          <th>المادة</th><th>المستوى</th><th>التاريخ</th><th>الوقت</th>
        </tr>
      </thead>
      <tbody>
        ${recentSessions.map(s => `
          <tr>
            <td><strong>${s.subject_name}</strong></td>
            <td>${s.level_name}</td>
            <td>${new Date(s.session_date).toLocaleDateString('ar-MA')}</td>
            <td>${s.session_time || '-'}</td>
          </tr>`).join('')}
      </tbody>
    </table>
  </div>
</div>` : ''}

<script>
function onFilterChange() {
  const subjectId = document.getElementById('subject_id').value;
  const levelId = document.getElementById('level_id').value;
  loadStudents(subjectId, levelId, 'studentsContainer');
}
</script>
` }) %>
