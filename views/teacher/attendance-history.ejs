<%- include('../layout', { body: `
<div class="page-header">
  <div>
    <div class="page-title"><i class="fas fa-history" style="color: var(--primary-light)"></i> سجل الحصص</div>
    <div class="page-subtitle">جميع الحصص التي سجلتها</div>
  </div>
  <a href="/teacher/dashboard" class="btn btn-primary">
    <i class="fas fa-plus"></i> تسجيل حصة جديدة
  </a>
</div>

<div class="card">
  ${sessions.length === 0 ? `
    <div class="empty-state">
      <div class="empty-icon">📋</div>
      <div class="empty-title">لا توجد حصص مسجلة بعد</div>
      <p>ابدأ بتسجيل أول حصة من لوحة التحكم</p>
    </div>` : `
  <div class="table-wrapper">
    <table>
      <thead>
        <tr>
          <th>المادة</th><th>المستوى</th><th>التاريخ</th><th>الوقت</th>
          <th>حاضرون</th><th>غائبون</th><th>المجموع</th><th>تفاصيل</th>
        </tr>
      </thead>
      <tbody>
        ${sessions.map(s => `
          <tr>
            <td><strong>${s.subject_name}</strong></td>
            <td>${s.level_name}</td>
            <td>${new Date(s.session_date).toLocaleDateString('ar-MA')}</td>
            <td>${s.session_time || '-'}</td>
            <td><span class="badge badge-present">✅ ${s.present}</span></td>
            <td><span class="badge badge-absent">❌ ${s.absent}</span></td>
            <td><span class="badge badge-info">${s.total}</span></td>
            <td>
              <a href="/teacher/session/${s.id}" class="btn btn-sm btn-outline">
                <i class="fas fa-eye"></i> عرض
              </a>
            </td>
          </tr>`).join('')}
      </tbody>
    </table>
  </div>`}
</div>
` }) %>
