<%
  const title = 'Détail Séance';
  const activeMenu = 'seances';
  const dateFormatted = new Date(date).toLocaleDateString('fr-MA', {
    weekday: 'long', day: '2-digit', month: 'long', year: 'numeric'
  });
%>
<%- include('partials/header') %>

<!-- Breadcrumb -->
<nav aria-label="breadcrumb" class="mb-3">
  <ol class="breadcrumb">
    <li class="breadcrumb-item"><a href="/admin/seances" class="text-decoration-none"><i class="bi bi-calendar2-check me-1"></i>Séances</a></li>
    <li class="breadcrumb-item active"><%= MATIERES_LABELS[matiere] %> — <%= dateFormatted %></li>
  </ol>
</nav>

<!-- Header de la séance -->
<div class="card mb-4" style="border-left: 4px solid var(--accent, #e8a020)">
  <div class="card-body">
    <div class="row g-3 align-items-center">
      <div class="col-md-6">
        <div class="text-muted small text-uppercase fw-semibold mb-1">Séance</div>
        <div class="fs-5 fw-bold"><%= MATIERES_LABELS[matiere] %></div>
        <div class="text-muted"><i class="bi bi-calendar3 me-1"></i><%= dateFormatted %></div>
        <div class="mt-1"><i class="bi bi-person-badge me-1 text-primary"></i>Professeur : <strong><%= profName %></strong></div>
      </div>
      <div class="col-md-6">
        <div class="row g-2 text-center">
          <div class="col-4">
            <div class="p-2 rounded" style="background:#f0f4f8">
              <div class="fw-bold fs-4"><%= lignes.length %></div>
              <div class="small text-muted">Total</div>
            </div>
          </div>
          <div class="col-4">
            <div class="p-2 rounded" style="background:#d1fae5">
              <div class="fw-bold fs-4 text-success"><%= presents %></div>
              <div class="small text-muted">Présents</div>
            </div>
          </div>
          <div class="col-4">
            <div class="p-2 rounded" style="background:#fee2e2">
              <div class="fw-bold fs-4 text-danger"><%= absents %></div>
              <div class="small text-muted">Absents</div>
            </div>
          </div>
        </div>
        <% const taux = lignes.length > 0 ? Math.round(presents / lignes.length * 100) : 0; %>
        <div class="mt-2">
          <div class="d-flex justify-content-between small text-muted mb-1">
            <span>Taux de présence</span><span class="fw-semibold"><%= taux %>%</span>
          </div>
          <div class="progress" style="height:8px">
            <div class="progress-bar <%= taux >= 80 ? 'bg-success' : taux >= 50 ? 'bg-warning' : 'bg-danger' %>"
              style="width:<%= taux %>%"></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Liste élèves -->
<div class="card">
  <div class="card-header fw-semibold d-flex justify-content-between align-items-center">
    <span><i class="bi bi-people me-2"></i>Liste des élèves</span>
    <div class="d-flex gap-2">
      <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i><%= presents %> présents</span>
      <span class="badge bg-danger"><i class="bi bi-x-circle me-1"></i><%= absents %> absents</span>
    </div>
  </div>
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead>
          <tr>
            <th>#</th>
            <th>Élève</th>
            <th>Niveau</th>
            <th class="text-center">Statut</th>
          </tr>
        </thead>
        <tbody>
          <% lignes.forEach((l, i) => { %>
          <tr style="<%= !l.present ? 'background:rgba(220,53,69,.04)' : '' %>">
            <td class="text-muted small"><%= i + 1 %></td>
            <td class="fw-medium"><%= l.student.prenom %> <%= l.student.nom %></td>
            <td>
              <span class="badge" style="background:#e3edf7;color:#1a3a5c">
                <%= NIVEAUX_LABELS[l.student.niveau] %>
              </span>
            </td>
            <td class="text-center">
              <% if (l.present) { %>
                <span class="badge bg-success px-3">
                  <i class="bi bi-check-lg me-1"></i>Présent
                </span>
              <% } else { %>
                <span class="badge bg-danger px-3">
                  <i class="bi bi-x-lg me-1"></i>Absent
                </span>
              <% } %>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- Bouton retour -->
<div class="mt-3">
  <a href="/admin/seances" class="btn btn-outline-secondary btn-sm">
    <i class="bi bi-arrow-left me-1"></i>Retour aux séances
  </a>
</div>

<%- include('partials/footer') %>
